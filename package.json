{
  "name": "cube-rolling-puzzle",
  "version": "1.0.0",
  "description": "A 3D puzzle game where players roll a 1x1x2 cuboid to reach a target hole",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "generate": "tsx tools/map-batch-generator.ts",
    "validate": "tsx tools/map-batch-generator.ts --validate"
  },
  "dependencies": {
    "@babylonjs/core": "^7.34.0",
    "@babylonjs/gui": "^7.34.0",
    "@babylonjs/materials": "^7.34.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "tsx": "^4.19.0"
  }
}
